{
    "name": "backend",
    "version": "1.0.0",
    "description": "Backend Fastify para ecommerce Atelie Guadalupe.",
    "main": "app.ts",
    "directories": {
        "test": "test"
    },
    "scripts": {
        "test": "pnpm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
        "start": "pnpm run build:ts && fastify start -l info dist/app.js",
        "build:ts": "tsc",
        "watch:ts": "tsc -w",
        "dev": "pnpm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm run watch:ts\" \"pnpm run dev:start\"",
        "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
        "prisma:generate": "pnpm exec prisma generate",
        "prisma:migrate:dev": "pnpm exec prisma migrate dev",
        "prisma:seed": "ts-node prisma/seed.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fastify/autoload": "^6.0.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/sensible": "^6.0.0",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "bcrypt": "^6.0.0",
        "dotenv": "^17.3.1",
        "fastify": "^5.0.0",
        "fastify-cli": "^7.4.1",
        "fastify-plugin": "^5.0.0",
        "pg": "^8.20.0",
        "prisma": "^7.5.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^24.0.8",
        "c8": "^10.1.2",
        "concurrently": "^9.0.0",
        "fastify-tsconfig": "^3.0.0",
        "ts-node": "^10.4.0",
        "typescript": "~5.9.2"
    }
}
